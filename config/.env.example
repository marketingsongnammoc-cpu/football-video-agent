# Claude API (script_gen + translator + content_filter)
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud TTS — đặt path tới file service account JSON
# Hoặc dùng `gcloud auth application-default login` ở local dev và bỏ dòng này
GOOGLE_APPLICATION_CREDENTIALS=config/google-credentials.json

# (Tuỳ chọn) Override voice mặc định
# GOOGLE_TTS_VOICE=vi-VN-Neural2-D
